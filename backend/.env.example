# Copy this to .env and fill in your values
# cp .env.example .env

# ── Database (default: SQLite, no setup needed) ───────────────
DATABASE_URL=sqlite:///./quorum.db

# ── JWT (change this to any long random string) ───────────────
JWT_SECRET=change-me-to-something-long-and-random-please

# ── LLM — using Groq (FREE at console.groq.com) ──────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_key_here

# ── OpenAI (optional, leave blank if using Groq) ─────────────
OPENAI_API_KEY=

# ── GitHub (optional, for ingesting commit history) ───────────
GITHUB_TOKEN=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
