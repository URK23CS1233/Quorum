# ── Required ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Database (default: SQLite, zero config) ───────────────────
DATABASE_URL=sqlite:///./quorum.db
# For PostgreSQL: DATABASE_URL=postgresql://quorum:quorum123@localhost:5432/quorum

# ── JWT (change SECRET_KEY in production!) ───────────────────
SECRET_KEY=quorum-super-secret-change-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── GitHub (optional) ─────────────────────────────────────────
GITHUB_TOKEN=ghp_...your-token-here...

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Production stores (optional — default uses local LanceDB/NetworkX) ──
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_URL=bolt://localhost:7687
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=quorum123
# VECTOR_DB_PROVIDER=qdrant
# QDRANT_PATH=http://localhost:6333
